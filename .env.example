NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://bravy:bravy123@localhost:5432/chat_bullq

# JWT
JWT_SECRET=change-me-generate-with-node-e-require-crypto-randomBytes-64-toString-hex
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-generate-another-different-one
JWT_REFRESH_EXPIRATION=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS
CORS_ORIGIN=http://localhost:3000

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=bravy
MINIO_SECRET_KEY=bravy123minio
MINIO_BUCKET=chat-bullq

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bravy.com

OPENAI_API_KEY=sk-proj-your-key-here

# ─────────────────────────────────────────────────────────────
# Opcionais / avançados (habilitam features específicas)
# ─────────────────────────────────────────────────────────────
# URL pública desta API (links, webhooks de retorno)
APP_URL=http://localhost:3001
# Redis com senha (Render Key Value interno normalmente NÃO precisa)
REDIS_PASSWORD=
# IA — Anthropic (além de OPENAI_API_KEY já acima)
ANTHROPIC_API_KEY=
# Motor de automações (true para habilitar workers de automação)
AUTOMATIONS_ENABLED=false
# Integração Google (Sofia / agenda / Drive Meet) — opcional
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_SA_JSON_B=
DRIVE_MEET_FOLDER_ID=
SOFIA_CALENDAR_ID=
SOFIA_MEETING_INTERNAL_ATTENDEES=
# Integração Hoppe — opcional
HOPPE_API_KEY=
HOPPE_BASE_URL=
# Integração Members / Trivapp — opcional
MEMBERS_ADMIN_KEY=
MEMBERS_TENANT_BRAVY=
MEMBERS_TRIVAPP_URL=
# IDs de agentes de operação do cliente — opcional
CLIENT_OPS_AGENT_IDS=
